generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum VrstaJedinice {
  KUCA
  APARTMAN
  STAN
}

enum IzvorRezervacije {
  DIREKTNO
  ADMIN
  WEB
  BOOKING
  AIRBNB
  TEKUCI_RACUN
  OSTALO
}

enum StatusRezervacije {
  UPIT
  CEKA_POTVRDU
  CEKA_AKONTACIJU
  REZERVIRANO
  POTVRDENO
  CEKA_OSTATAK
  PLACENO
  OTKAZANO
  ZAVRSENO
  OBRISANO
}

enum TipZadatka {
  CHECK_IN
  CHECK_OUT
  ZAVRSNO_CISCENJE
  MEDJUCISCENJE
  PROMJENA_POSTELJINE
  MEDJUCISCENJE_I_POSTELJINA
  DODATNO_CISCENJE
}

enum StatusZadatka {
  CEKA
  U_TOKU
  GOTOVO
  OTKAZANO
}

enum BojaPerioda {
  PLAVA
  ZELENA
  ZUTA
  NARANCASTA
  CRVENA
  LJUBICASTA
}

enum StatusPrijedlogaAkcije {
  CEKA_ODOBRENJE
  ODOBRENO
  ODBIJENO
}

enum StatusNarudzbeCiscenja {
  KREIRANO
  POSLANO
  POTVRDJENO
  OTKAZANO
}

enum TipPlacanja {
  POTVRDA_REZERVACIJE
  AKONTACIJA
  OSTATAK
  RAZLIKA
  CIJELI_IZNOS
  POVRAT
}

enum StatusPlacanja {
  CEKA_PLACANJE
  ZAHTJEV_POSLAN
  PLACENO
  DJELOMICNO_PLACENO
  NEUSPJELO
  OTKAZANO
  POVRAT
}

enum TipEmaila {
  POTVRDA_REZERVACIJE
  ZAHTJEV_AKONTACIJA
  ZAHTJEV_OSTATAK
  ZAHTJEV_RAZLIKA
  HVALA_NA_PLACANJU
  PROMJENA_REZERVACIJE
  OTKAZIVANJE_REZERVACIJE
  RACUN
  DOBRODOSLICA
}

enum StatusEmaila {
  POSLANO
  GRESKA
}

model Objekt {
  id          String  @id @default(uuid())
  naziv       String
  opis        String?
  mjesto      String?
  imaBazen    Boolean @default(false)
  grupaBazena String?

  nazivZaRacun     String?
  oibZaRacun       String?
  adresaZaRacun    String?
  mjestoZaRacun    String?
  ibanZaRacun      String?
  emailZaRacun     String?
  ccEmailZaRacun   String?
  telefonZaRacun   String?
  napomenaNaRacunu String?
  prefixRacuna     String?

  aktivan   Boolean @default(true)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jedinice Jedinica[]
  racuni   Racun[]
  slike    SlikaObjekta[]
  troskovi Trosak[]

  @@index([naziv])
}

model Jedinica {
  id                     String        @id @default(uuid())
  objektId               String
  naziv                  String
  sifra                  String?
  vrsta                  VrstaJedinice
  osnovniKapacitet       Int
  dodatniKapacitet       Int           @default(0)
  ukupniKapacitet        Int
  brojKupaona            Int           @default(1)
  brojSpavacihSoba       Int?
  imaSpavanjeUDnevnom    Boolean       @default(false)
  sharedPool             Boolean       @default(false)
  aktivna                Boolean       @default(true)
  postotakAkontacije     Float         @default(30)
  autoGapDiscountEnabled Boolean       @default(true)
  gapDiscountPercent     Float         @default(15)
  gapDiscountMaxNights   Int           @default(3)
  napomena               String?
  sortOrder              Int           @default(0)
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  objekt                   Objekt                     @relation(fields: [objektId], references: [id], onDelete: Cascade)
  rezervacije              Rezervacija[]
  zadaci                   Zadatak[]
  cjenici                  Cjenik[]
  akcije                   Akcija[]
  prijedloziAkcija         PrijedlogAkcije[]
  blokade                  BlokadaJedinice[]
  vanjskiKalendari         VanjskiKalendar[]
  blokadeVanjskogKalendara BlokadaVanjskogKalendara[]

  cijeneCiscenja CijenaCiscenjaAgencije[]
  stavkeCiscenja CiscenjeStavka[]
  cjenikCiscenja CjenikCiscenjaJedinice?
  troskovi       Trosak[]

  slike SlikaObjekta[]

  oprema JedinicaOprema[]

  ttlockBrave JedinicaTtlockBrava[]

  @@index([objektId])
}

model Gost {
  id        String   @id @default(uuid())
  ime       String
  prezime   String?
  email     String?  @unique
  telefon   String?
  adresa    String?
  grad      String?
  drzava    String?
  jezik     String?  @default("hr")
  napomena  String?
  oznake    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rezervacije Rezervacija[]
}

model Rezervacija {
  id         String            @id @default(uuid())
  jedinicaId String
  gostId     String?
  izvor      IzvorRezervacije  @default(DIREKTNO)
  status     StatusRezervacije @default(CEKA_POTVRDU)

  datumOd     DateTime
  datumDo     DateTime
  brojNocenja Int
  brojOsoba   Int

  iznosUkupno  Float?
  iznosPotvrde Float?
  iznosPlaceno Float?

  iznosOsnovni        Float?
  popustPostotak      Float?
  popustIznos         Float?
  dogovoreniIznos     Float?
  iznosOstatka        Float?
  rokUplateAkontacije DateTime?
  rokUplateOstatka    DateTime?
  razlogPopusta       String?

  // Pravila naplate spremljena na samu rezervaciju
  // da se kasnija promjena globalnih postavki ne odrazi na stare rezervacije.
  danaVrijediAkontacija     Int?
  danaPrijeDolaskaOstatak   Int?
  danaPrijeDolaskaPlaceno   Int?
  zadnjiPodsjetnikOstatkaAt DateTime?
  automatskoOtkazivanje     Boolean   @default(true)

  placenoKarticom      Boolean @default(false)
  valuta               String  @default("EUR")
  bookingExternalId    String?
  blokadaId            String? @unique // veza na BlokadaVanjskogKalendara (samo za izvor=BOOKING)
  bookingIcalUid       String? @unique // iCal UID iz BlokadaVanjskogKalendara.uid (stabilan kroz iCal sync)
  napomena             String?
  eCheckinLink         String? // link na vanjsku eCheckin/prijava-gosta formu (ručni unos)
  automatskoCiscenje   Boolean @default(true)
  automatskaPosteljina Boolean @default(true)

  // Fleksibilno čišćenje (feat/ciscenje-fleksibilno).
  // odgodaCiscenjaDana: pomak ZAVRSNO_CISCENJE u danima naprijed od datumDo
  //   (A — admin potvrdi odgodu kad nema ulaza sljedećih dana). 0 = bez pomaka.
  // ciscenjeOdOverride: per-slučaj vrijeme početka čišćenja "HH:MM"
  //   (C — npr. "08:00" kad nema žurbe). null = koristi globalni default iz
  //   CiscenjeMailPostavke. SQL stupci dodani ručno u Supabase.
  // NO-OP u F0: nitko još ne čita ova polja (ožičavaju se u F1–F3).
  odgodaCiscenjaDana   Int     @default(0)
  ciscenjeOdOverride   String?

  obrisanoAt       DateTime?
  obrisaoKorisnik String?
  statusPrijeBrisanja StatusRezervacije?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jedinica Jedinica  @relation(fields: [jedinicaId], references: [id], onDelete: Cascade)
  gost     Gost?     @relation(fields: [gostId], references: [id], onDelete: SetNull)
  zadaci   Zadatak[]

  placanja Placanje[]
  racuni   Racun[]
  emailovi EmailLog[]
  promjene RezervacijaPromjena[]
  ttlockSifre RezervacijaTtlockSifra[]
  whatsappPoruke WhatsappPoruka[]

  @@index([jedinicaId])
  @@index([datumOd, datumDo])
  @@index([status])
  @@index([izvor])
  @@index([rokUplateAkontacije])
  @@index([rokUplateOstatka])
  @@index([blokadaId])
  @@index([bookingIcalUid])
}

model RezervacijaPromjena {
  id            String @id @default(uuid())
  rezervacijaId String

  tip    String
  opis   String?
  razlog String?

  stariPodaci String?
  noviPodaci  String?

  korisnikIme String?

  createdAt DateTime @default(now())

  rezervacija Rezervacija @relation(fields: [rezervacijaId], references: [id], onDelete: Cascade)

  @@index([rezervacijaId])
  @@index([tip])
  @@index([createdAt])
}

model Zadatak {
  id            String        @id @default(uuid())
  jedinicaId    String
  rezervacijaId String?
  datum         DateTime
  tip           TipZadatka
  status        StatusZadatka @default(CEKA)
  naslov        String
  opis          String?
  prioritet     Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  jedinica    Jedinica     @relation(fields: [jedinicaId], references: [id], onDelete: Cascade)
  rezervacija Rezervacija? @relation(fields: [rezervacijaId], references: [id], onDelete: SetNull)
  trosak      Trosak?

  @@index([jedinicaId])
  @@index([datum])
}

model Cjenik {
  id               String      @id @default(uuid())
  jedinicaId       String
  datumOd          DateTime
  datumDo          DateTime
  cijenaNocenja    Float
  minimalniBoravak Int         @default(2)
  bojaPerioda      BojaPerioda @default(ZELENA)
  aktivno          Boolean     @default(true)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  jedinica Jedinica @relation(fields: [jedinicaId], references: [id], onDelete: Cascade)

  @@index([jedinicaId])
  @@index([datumOd, datumDo])
}

model Akcija {
  id         String @id @default(uuid())
  jedinicaId String

  naziv String  @default("Posebna prilika")
  opis  String?

  datumOd DateTime
  datumDo DateTime

  brojOsoba Int?

  postotakPopusta Float?
  cijenaUkupno    Float?

  prikaziNaWebu Boolean @default(true)
  aktivna       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jedinica Jedinica @relation(fields: [jedinicaId], references: [id], onDelete: Cascade)

  @@index([jedinicaId])
  @@index([datumOd, datumDo])
  @@index([aktivna])
  @@index([prikaziNaWebu])
}

model PrijedlogAkcije {
  id               String                 @id @default(uuid())
  jedinicaId       String
  datumOd          DateTime
  datumDo          DateTime
  brojNocenja      Int
  predlozeniPopust Float
  razlog           String?
  status           StatusPrijedlogaAkcije @default(CEKA_ODOBRENJE)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  jedinica Jedinica @relation(fields: [jedinicaId], references: [id], onDelete: Cascade)

  @@index([jedinicaId])
  @@index([status])
  @@index([datumOd, datumDo])
}

model BlokadaJedinice {
  id         String   @id @default(uuid())
  jedinicaId String
  datumOd    DateTime
  datumDo    DateTime
  razlog     String?
  izvor      String   @default("ADMIN")
  externalId String?
  aktivna    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  jedinica Jedinica @relation(fields: [jedinicaId], references: [id], onDelete: Cascade)

  @@index([jedinicaId])
  @@index([datumOd, datumDo])
  @@index([externalId])
}

model VanjskiKalendar {
  id         String    @id @default(uuid())
  jedinicaId String
  naziv      String
  izvor      String    @default("BOOKING")
  icalUrl    String
  aktivan    Boolean   @default(true)
  lastSyncAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  jedinica Jedinica                   @relation(fields: [jedinicaId], references: [id], onDelete: Cascade)
  blokade  BlokadaVanjskogKalendara[]

  @@index([jedinicaId])
  @@index([izvor])
}

model BlokadaVanjskogKalendara {
  id                String @id @default(uuid())
  vanjskiKalendarId String
  jedinicaId        String

  izvor  String  @default("BOOKING")
  uid    String?
  naslov String?

  // Excel obogaćivanje (iz Booking "Prijava s kontaktnim podacima")
  gostIme            String?
  gostPrezime        String?
  gostEmail          String?
  gostTelefon        String?
  gostDrzava         String?
  brojOsoba          Int?
  brojOdraslih       Int?
  brojDjece          Int?
  dobDjece           String?
  iznosBruto         Float?
  iznosProvizije     Float?
  iznosNeto          Float?
  valuta             String    @default("EUR")
  bookingId          String?
  excelImportiranoAt DateTime?

  datumOd DateTime
  datumDo DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vanjskiKalendar VanjskiKalendar @relation(fields: [vanjskiKalendarId], references: [id], onDelete: Cascade)
  jedinica        Jedinica        @relation(fields: [jedinicaId], references: [id], onDelete: Cascade)

  @@unique([vanjskiKalendarId, uid])
  @@index([vanjskiKalendarId])
  @@index([jedinicaId])
  @@index([datumOd])
  @@index([datumDo])
  @@index([uid])
  @@index([bookingId])
}

model BookingExcelImport {
  id String @id @default(uuid())

  objektKey   String // "EVA" | "MARTY" | "HOUSE_ART"
  objektNaziv String // npr. "Apartments Eva" (snapshot za prikaz)
  imeFajla    String?

  brojRedakaUkupno Int @default(0)
  brojObogaceno    Int @default(0)
  brojPreskoceno   Int @default(0)
  brojGresaka      Int @default(0)
  brojObrisano     Int @default(0)

  greske         String? // JSON array kao string, npr: ["Red 5: jedinica ne postoji", ...]
  obrisaneRezIds String? // JSON array obrisanih rezervacija pri FULL REPLACE uploadu

  korisnikIme String?

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([objektKey])
}

model CiscenjeAgencija {
  id       String  @id @default(uuid())
  naziv    String
  email    String
  ccEmails String?
  telefon  String?
  aktivna  Boolean @default(true)
  napomena String?

  narudzbe CiscenjeNarudzba[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([aktivna])
}

model CijenaCiscenjaAgencije {
  id         String @id @default(uuid())
  jedinicaId String
  cijena     Float

  vrijediOd DateTime
  vrijediDo DateTime?
  aktivna   Boolean   @default(true)

  jedinica Jedinica @relation(fields: [jedinicaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jedinicaId])
  @@index([aktivna])
}

model CiscenjeNarudzba {
  id         String                 @id @default(uuid())
  agencijaId String
  datumOd    DateTime
  datumDo    DateTime
  status     StatusNarudzbeCiscenja @default(KREIRANO)

  emailPrimatelja  String
  ccEmailsSnapshot String?

  subject    String?
  tekstMaila String?

  poslanoEmail Boolean   @default(false)
  poslanoAt    DateTime?

  napomena String?

  agencija CiscenjeAgencija @relation(fields: [agencijaId], references: [id], onDelete: Cascade)
  stavke   CiscenjeStavka[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agencijaId])
  @@index([datumOd, datumDo])
  @@index([status])
}

model CiscenjeStavka {
  id         String  @id @default(uuid())
  narudzbaId String
  jedinicaId String
  zadatakId  String?

  datum         DateTime
  tip           TipZadatka
  nazivJedinice String
  nazivObjekta  String?
  opis          String?

  cijena      Float
  obavljeno   Boolean   @default(false)
  obavljenoAt DateTime?

  narudzba CiscenjeNarudzba @relation(fields: [narudzbaId], references: [id], onDelete: Cascade)
  jedinica Jedinica         @relation(fields: [jedinicaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([narudzbaId])
  @@index([jedinicaId])
  @@index([datum])
  @@index([obavljeno])
}

model CiscenjeMailPostavke {
  id String @id @default(uuid())

  aktivno Boolean @default(true)

  saljiPonedjeljak Boolean @default(true)
  saljiUtorak      Boolean @default(false)
  saljiSrijeda     Boolean @default(false)
  saljiCetvrtak    Boolean @default(false)
  saljiPetak       Boolean @default(true)
  saljiSubota      Boolean @default(false)
  saljiNedjelja    Boolean @default(false)

  martyBazenPonedjeljak Boolean @default(false)
  martyBazenUtorak      Boolean @default(false)
  martyBazenSrijeda     Boolean @default(false)
  martyBazenCetvrtak    Boolean @default(false)
  martyBazenPetak       Boolean @default(false)
  martyBazenSubota      Boolean @default(false)
  martyBazenNedjelja    Boolean @default(false)

  satSlanja    Int @default(8)
  minutaSlanja Int @default(0)

  // Globalni default vremena kad čistačice mogu početi čišćenje (C —
  // feat/ciscenje-fleksibilno). Prikazuje se u novom stupcu "Čišćenje od"
  // u mailu/PDF-u; per-slučaj se override-a preko Rezervacija.ciscenjeOdOverride.
  // SQL stupci dodani ručno u Supabase. NO-OP u F0: još se ne čita.
  ciscenjeOdSat    Int @default(10)
  ciscenjeOdMinuta Int @default(0)

  brojDanaUnaprijed Int @default(7)

  // Jednokratna napomena agenciji — šalje se uz sljedeći plan čišćenja i briše
  // se (null) odmah nakon uspješnog slanja maila. SQL stupac dodan ručno u Supabase.
  napomenaAgenciji String?

  // Cjenik (Faza 1 — sustav troškova Adonija): fiksne stope + dani Stubište Eva.
  rubeninaCijenaPoKg    Float @default(3.30)
  generalnoCijenaPoSatu Float @default(18.00)
  stubisteCijena        Float @default(10.00)
  bazenCijena           Float @default(25.00)

  evaStubistePonedjeljak Boolean @default(false)
  evaStubisteUtorak      Boolean @default(false)
  evaStubisteSrijeda     Boolean @default(false)
  evaStubisteCetvrtak    Boolean @default(false)
  evaStubistePetak       Boolean @default(false)
  evaStubisteSubota      Boolean @default(false)
  evaStubisteNedjelja    Boolean @default(false)

  // Redizajn dana čišćenja (feat/ciscenje-dani-datumi): umjesto fiksnih dana u
  // tjednu (gore, sada MRTVI stupci) biramo KONKRETNE datume. Format svakog
  // elementa: "YYYY-MM-DD" (wall-clock, Europe/Zagreb) — namjerno String[] a NE
  // DateTime[] da izbjegnemo TZ/DST pomak. Usporedba: lista.includes(formatYMD(d)).
  // @default([]) — prazno dok korisnik ne označi datume; nitko ne čita dok ne
  // dođe F2/F3. SQL stupci dodani ručno u Supabase (text[] NOT NULL DEFAULT '{}').
  martyBazenDatumi    String[] @default([])
  evaStubisteDatumi   String[] @default([])
  martyStubisteDatumi String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum KategorijaTroska {
  CISCENJE
  POSTELJINA
  BAZEN
  STUBISTE
  RUBENINA
  GENERALNO
  IZVANREDNO
}

enum IzvorTroska {
  AUTO
  RUCNO
}

model CjenikCiscenjaJedinice {
  id               String @id @default(cuid())
  jedinicaId       String @unique
  cijenaCiscenja   Float  @default(0)
  cijenaPosteljina Float  @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jedinica Jedinica @relation(fields: [jedinicaId], references: [id], onDelete: Cascade)
}

model Trosak {
  id              String           @id @default(cuid())
  datum           DateTime
  kategorija      KategorijaTroska
  izvor           IzvorTroska
  jedinicaId      String?
  objektId        String?
  zadatakId       String?          @unique
  opis            String?
  kolicina        Float?
  jedinicnaCijena Float?
  iznos           Float
  storniran       Boolean          @default(false)
  stornoRazlog    String?
  stornoAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jedinica Jedinica? @relation(fields: [jedinicaId], references: [id], onDelete: SetNull)
  objekt   Objekt?   @relation(fields: [objektId], references: [id], onDelete: SetNull)
  zadatak  Zadatak?  @relation(fields: [zadatakId], references: [id], onDelete: SetNull)

  @@index([datum])
  @@index([kategorija])
  @@index([izvor])
  @@index([jedinicaId])
  @@index([objektId])
  @@index([storniran])
}

model Placanje {
  id            String @id @default(uuid())
  rezervacijaId String

  tip    TipPlacanja
  status StatusPlacanja @default(CEKA_PLACANJE)

  iznos  Float
  valuta String @default("EUR")

  // 🔥 STRIPE PODACI
  provider        String? // npr. STRIPE
  providerId      String? // Stripe Checkout Session ID
  paymentIntentId String? // 🔥 KLJUČNO za capture kasnije
  paymentUrl      String? // Stripe checkout URL

  // 🧠 LOGIKA PLAĆANJA
  nacinPlacanja String? // KARTICA
  napomena      String?

  placenoAt DateTime?

  // 🔥 ZA AUTORIZACIJU
  autoriziranoAt DateTime? // kad je kartica autorizirana
  expiresAt      DateTime? // do kada vrijedi autorizacija (npr. +1h)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rezervacija Rezervacija @relation(fields: [rezervacijaId], references: [id], onDelete: Cascade)
  racuni      Racun[]

  @@index([rezervacijaId])
  @@index([status])
  @@index([tip])
}

model Racun {
  id            String  @id @default(uuid())
  rezervacijaId String
  placanjeId    String?
  objektId      String?

  brojRacuna String
  iznos      Float
  valuta     String @default("EUR")

  nazivIzdavatelja   String?
  oibIzdavatelja     String?
  adresaIzdavatelja  String?
  mjestoIzdavatelja  String?
  ibanIzdavatelja    String?
  emailIzdavatelja   String?
  telefonIzdavatelja String?

  pdfUrl      String?
  poslanGostu Boolean @default(false)

  createdAt DateTime @default(now())

  rezervacija Rezervacija @relation(fields: [rezervacijaId], references: [id], onDelete: Cascade)
  placanje    Placanje?   @relation(fields: [placanjeId], references: [id], onDelete: SetNull)
  objekt      Objekt?     @relation(fields: [objektId], references: [id], onDelete: SetNull)

  @@unique([brojRacuna])
  @@index([rezervacijaId])
  @@index([placanjeId])
  @@index([objektId])
}

model EmailLog {
  id            String  @id @default(uuid())
  rezervacijaId String?

  to      String
  subject String
  tip     TipEmaila

  status StatusEmaila @default(POSLANO)
  greska String?

  createdAt DateTime @default(now())

  rezervacija Rezervacija? @relation(fields: [rezervacijaId], references: [id], onDelete: Cascade)

  @@index([rezervacijaId])
  @@index([tip])
  @@index([status])
}

model SlikaObjekta {
  id    String  @id @default(uuid())
  url   String
  naziv String?
  opis  String?

  objektId   String?
  jedinicaId String?

  prikaziNaPocetnoj   Boolean @default(false)
  prikaziNaDashboardu Boolean @default(false)

  sortOrder Int     @default(0)
  aktivna   Boolean @default(true)

  createdAt DateTime @default(now())

  objekt   Objekt?   @relation(fields: [objektId], references: [id], onDelete: Cascade)
  jedinica Jedinica? @relation(fields: [jedinicaId], references: [id], onDelete: Cascade)

  @@index([objektId])
  @@index([jedinicaId])
  @@index([prikaziNaPocetnoj, aktivna])
  @@index([prikaziNaDashboardu, aktivna])
}

model OpremaJedinice {
  id         String  @id @default(uuid())
  naziv      String
  kategorija String?
  ikona      String?
  aktivna    Boolean @default(true)
  sortOrder  Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jedinice JedinicaOprema[]

  @@unique([naziv])
  @@index([kategorija])
}

model JedinicaOprema {
  id         String @id @default(uuid())
  jedinicaId String
  opremaId   String

  jedinica Jedinica       @relation(fields: [jedinicaId], references: [id], onDelete: Cascade)
  oprema   OpremaJedinice @relation(fields: [opremaId], references: [id], onDelete: Cascade)

  @@unique([jedinicaId, opremaId])
  @@index([jedinicaId])
  @@index([opremaId])
}

model PostavkeNaplate {
  id String @id @default(uuid())

  danaVrijediPozivAkontacije      Int @default(3)
  danaPrijeDolaskaSlanjeOstatka   Int @default(7)
  danaPrijeDolaskaMoraBitiPlaceno Int @default(3)

  danaPrijeDolaskaPunaNaplata Int @default(30)

  // Koliko dana prije dolaska cron šalje welcome mail / check-in SMS.
  mailDanaPrije Int @default(5)
  smsDanaPrije  Int @default(3)

  appUrl String?

  automatskiOtkaziBezAkontacije    Boolean @default(true)
  automatskiSaljiPodsjetnikOstatka Boolean @default(true)

  tekstPozivaAkontacije   String?
  tekstPodsjetnikaOstatka String?
  adminEmails String?
  emailPredlozakRezervacija String?
  tekstAdminNoveRezervacije String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum TtlockTipBrave {
  GLAVNI_ULAZ
  VRATA_JEDINICE
  KAPIJA
  OSTALO
}

enum TtlockStatusSifre {
  CEKA
  POSLANO
  GRESKA
  OBRISANO
  ISTEKLO
}

model TtlockBrava {
  id String @id @default(uuid())

  naziv String
  lockId String @unique

  tip TtlockTipBrave @default(OSTALO)

  objektNaziv String?
  napomena    String?

  aktivna Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jedinice JedinicaTtlockBrava[]
  sifre    RezervacijaTtlockSifra[]
  pristupi TtlockPristupBrava[]

  @@index([lockId])
  @@index([aktivna])
  @@index([tip])
}

model JedinicaTtlockBrava {
  id String @id @default(uuid())

  jedinicaId String
  bravaId    String

  glavnaZaJedinicu Boolean @default(false)
  sortOrder        Int     @default(0)

  createdAt DateTime @default(now())

  jedinica Jedinica    @relation(fields: [jedinicaId], references: [id], onDelete: Cascade)
  brava    TtlockBrava @relation(fields: [bravaId], references: [id], onDelete: Cascade)

  @@unique([jedinicaId, bravaId])
  @@index([jedinicaId])
  @@index([bravaId])
}

model RezervacijaTtlockSifra {
  id String @id @default(uuid())

  rezervacijaId String
  bravaId       String

  sifra String

  vrijediOd DateTime
  vrijediDo DateTime

  status TtlockStatusSifre @default(CEKA)
  greska String?

  ttlockKeyboardPwdId String?

  poslanaGostu Boolean @default(false)
  poslanaAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rezervacija Rezervacija @relation(fields: [rezervacijaId], references: [id], onDelete: Cascade)
  brava       TtlockBrava  @relation(fields: [bravaId], references: [id], onDelete: Cascade)

  @@unique([rezervacijaId, bravaId])
  @@index([rezervacijaId])
  @@index([bravaId])
  @@index([status])
}

// Povijest poslanih WhatsApp poruka gostu (check-in flow). Tablica se kreira
// ručnim SQL-om u Supabase (NE prisma migrate); ovaj model samo opisuje shemu
// za Prisma Client. Više redaka po rezervaciji (povijest + multi-unit po retku).
model WhatsappPoruka {
  id            String   @id @default(cuid())
  rezervacijaId String

  kanal        String   @default("SMS") // SMS / WHATSAPP — kojim je kanalom poslano
  primatelj    String // E.164 broj na koji je poslano
  templateSid  String?
  varijable    Json // {1: ime, 2: objekt, 3: datum, 4: sifra, 5: upute, 6: kontakt}
  tekstPregled String // čitljiv tekst poruke s ubačenim varijablama
  twilioSid    String? // Message/Provider ID iz odgovora (Infobip messageId / Twilio SID)

  status String // POSLANO / GRESKA
  greska String?

  poslanoAt DateTime @default(now())

  rezervacija Rezervacija @relation(fields: [rezervacijaId], references: [id], onDelete: Cascade)

  @@index([rezervacijaId])
  @@index([poslanoAt])
  @@index([kanal])
}

enum TtlockTipOsobe {
  GOST
  CISTACICA
  VLASNIK
  SERVIS
  OSTALO
}

enum TtlockStatusPristupa {
  AKTIVNO
  NEAKTIVNO
  GRESKA
}

model TtlockOsoba {
  id String @id @default(uuid())

  ime     String
  prezime String?
  email   String?
  telefon String?

  tip TtlockTipOsobe @default(OSTALO)

  napomena String?
  aktivna  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pristupi TtlockPristup[]

  @@index([tip])
  @@index([aktivna])
  @@index([ime])
}

model TtlockPristup {
  id String @id @default(uuid())

  osobaId String

  naziv String?
  sifra String

  vrijediOd DateTime?
  vrijediDo DateTime?

  status TtlockStatusPristupa @default(AKTIVNO)

  napomena String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  osoba TtlockOsoba @relation(fields: [osobaId], references: [id], onDelete: Cascade)
  brave TtlockPristupBrava[]

  @@index([osobaId])
  @@index([status])
  @@index([vrijediOd])
  @@index([vrijediDo])
}

model TtlockPristupBrava {
  id String @id @default(uuid())

  pristupId String
  bravaId   String

  pristup TtlockPristup @relation(fields: [pristupId], references: [id], onDelete: Cascade)
  brava   TtlockBrava   @relation(fields: [bravaId], references: [id], onDelete: Cascade)

  @@unique([pristupId, bravaId])
  @@index([pristupId])
  @@index([bravaId])
}